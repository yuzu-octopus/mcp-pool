<span class="material-symbols-outlined icon-{{ name }}" aria-hidden="true">{{ ms_names.get(name, name) }}</span>
{% endmacro %}

<button class="mobile-toggle" id="mobile-toggle" onclick="toggleSidebar()" aria-label="Toggle mobile menu" aria-controls="sidebar" aria-expanded="false"><span class="material-symbols-outlined" aria-hidden="true">menu</span></button>
<div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>
<a class="skip-link" href="#main-content">Skip to content</a>

<button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
  <span class="material-symbols-outlined icon-moon" aria-hidden="true">dark_mode</span>
  <span class="material-symbols-outlined icon-sun" aria-hidden="true">light_mode</span>
</button>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-brand">
    <div class="logo">{{ project.logo_svg }}</div>
    <div class="name">{{ project.name }}</div>
    <div class="tagline">{{ brand.tagline }}</div>
  </div>
  <hr class="sidebar-divider">
  <nav class="sidebar-nav" aria-label="Main navigation">
    <ul>
      <li><a href="#hero"><span class="icon">{{ icon("home") }}</span> Home</a></li>
      {% for section in sections %}
      {% set sidebar_icon = section.sidebar_icon | default(section.icon) %}
      {% set sidebar_title = section.sidebar_title | default(section.title) %}
      {% if sidebar_title %}
      <li><a href="#{{ section.id }}"><span class="icon">{{ icon(sidebar_icon) }}</span> {{ sidebar_title }}</a></li>
      {% endif %}
      {% endfor %}
    </ul>
  </nav>
  <hr class="sidebar-divider">
  <div class="sidebar-footer">
    <div>&copy; {{ current_year }} yuzu-octopus</div>
    <div>Generated by <a href="https://github.com/yuzu-octopus/ProjectSite" target="_blank" rel="noopener noreferrer">ProjectSite</a></div>
    <div>Powered by <a href="https://pages.github.com/" target="_blank" rel="noopener noreferrer">GitHub Pages</a></div>
  </div>
</aside>

<main class="main" id="main-content">

  <section id="hero" class="hero">
    <div class="container">
      <h1>{{ project.name }}</h1>
      <p class="tagline">{{ project.tagline }}</p>
      <p class="subtitle">{{ project.subtitle }}</p>
      <div class="cta">
        <a href="{{ project.github_url }}" class="btn btn-primary">View on GitHub</a>
      </div>
    </div>
  </section>

  {% for section in sections %}
  <section id="{{ section.id }}" class="reveal">
    <div class="container">
      {% if section.title %}
      <h2>{{ section.title }}</h2>
      {% endif %}

      {% if section.type == "features" %}
      <div class="grid">
        {% for item in section["items"] %}
        <div class="card">
          <h3>{{ item.title }}</h3>
          <p>{{ item.body }}</p>
        </div>
        {% endfor %}
      </div>

      {% elif section.type == "table" %}
      <div style="overflow-x: auto;">
      <table>
        <thead>
          <tr>{% for header in section.headers %}<th>{{ header }}</th>{% endfor %}</tr>
        </thead>
        <tbody>
          {% for row in section.rows %}
          <tr>{% for cell in row.cells %}<td>{{ cell }}</td>{% endfor %}</tr>
          {% endfor %}
        </tbody>
      </table>
      </div>

      {% elif section.type == "steps" %}
      <ul class="steps">
        {% for item in section["items"] %}
        <li><strong>{{ item.title }}</strong> &mdash; {{ item.body }}</li>
        {% endfor %}
      </ul>

      {% elif section.type == "terms" %}
      <ul class="terms">
        {% for item in section["items"] %}
        <li><span class="term">{{ item.term }}</span> &mdash; {{ item.definition }}</li>
        {% endfor %}
      </ul>

      {% elif section.type == "code_block" %}
      {% if section.language %}
      <pre><code class="language-{{ section.language }}">{{ section.code | e }}</code></pre>
      {% else %}
      <pre><code>{{ section.code | e }}</code></pre>
      {% endif %}

      {% elif section.type == "stack" %}
      <div class="stack">
        {% for item in section["items"] %}
        <span class="badge"><strong>{{ item.name }}</strong> &mdash; {{ item.description }}</span>
        {% endfor %}
      </div>

      {% elif section.type == "text" %}
      {{ section.body }}

      {% elif section.type == "links" %}
      <div class="links">
        {% for item in section["items"] %}
        <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer" class="link-card">
          <strong>{{ item.title }}</strong>
          <span>{{ item.description }}</span>
          <span class="link-arrow">&rarr;</span>
        </a>
        {% endfor %}
      </div>

      {% elif section.type == "custom" %}
      {{ section.body }}

      {% elif section.type == "notice" %}
      <div class="callout callout-{{ section.notice_type | default('info') }}">
        {{ section.body }}
      </div>

      {% elif section.type == "timeline" %}
      <ul class="timeline">
        {% for item in section["items"] %}
        <li class="timeline-item">
          <div class="timeline-date-col">{% if item.date %}<span class="timeline-date">{{ item.date }}</span>{% endif %}</div>
          <div class="timeline-marker"><div class="timeline-dot"></div></div>
          <div class="timeline-content">
            <strong>{{ item.title }}</strong>
            <p>{{ item.body }}</p>
          </div>
        </li>
        {% endfor %}
      </ul>

      {% elif section.type == "workflow" %}
      <div class="workflow">
        {% for item in section["items"] %}
        <div class="workflow-item">
          <div class="workflow-top">
            <div class="workflow-line"></div>
            <div class="workflow-dot">{{ loop.index }}</div>
            <div class="workflow-line"></div>
          </div>
          <div class="workflow-card">
            <h4>{{ item.title }}</h4>
            <p>{{ item.body }}</p>
          </div>
        </div>
        {% endfor %}
      </div>

      {% endif %}
    </div>
  </section>
  {% endfor %}

</main>

<script>
function toggleSidebar() {
  var btn = document.getElementById('mobile-toggle');
  var sidebar = document.querySelector('.sidebar');
  var overlay = document.getElementById('sidebar-overlay');
  var open = sidebar.classList.toggle('open');
  overlay.classList.toggle('open');
  btn.setAttribute('aria-expanded', open);
}

function closeSidebar() {
  document.querySelector('.sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('open');
  document.getElementById('mobile-toggle').setAttribute('aria-expanded', 'false');
}

document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape' && document.querySelector('.sidebar.open')) {
    closeSidebar();
  }
});

var scrollingProgrammatically = false;

document.querySelector('.sidebar-nav').addEventListener('click', function(e) {
  var link = e.target.closest('a[href^="#"]');
  if (link) {
    closeSidebar();
    setActiveLink(link.getAttribute('href').slice(1));
    scrollingProgrammatically = true;
    setTimeout(function() { scrollingProgrammatically = false; }, 800);
  }
});

function toggleTheme() {
  var html = document.documentElement;
  var current = html.getAttribute('data-theme');
  var next = current === 'light' ? 'dark' : 'light';
  html.setAttribute('data-theme', next);
  localStorage.setItem('theme', next);
  document.querySelector('meta[name="theme-color"]').content =
    next === 'light' ? '#FFFBEB' : '#282a36';
  updateFavicon();
}

document.querySelectorAll('pre').forEach(function(pre) {
  var wrapper = document.createElement('div');
  wrapper.className = 'code-block-wrapper';
  pre.parentNode.insertBefore(wrapper, pre);
  wrapper.appendChild(pre);
  var btn = document.createElement('button');
  btn.className = 'copy-btn';
  btn.setAttribute('aria-label', 'Copy code');
  btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">content_copy</span>';
  btn.addEventListener('click', function() {
    var codeNode = pre.querySelector('code');
    var text = codeNode ? codeNode.textContent : pre.textContent;
    navigator.clipboard.writeText(text).then(function() {
      btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">check</span>';
      btn.setAttribute('aria-label', 'Copied');
      setTimeout(function() {
        btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">content_copy</span>';
        btn.setAttribute('aria-label', 'Copy code');
      }, 2000);
    }).catch(function() {
      btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">close</span>';
      btn.setAttribute('aria-label', 'Copy failed');
      setTimeout(function() {
        btn.innerHTML = '<span class="material-symbols-outlined" aria-hidden="true">content_copy</span>';
        btn.setAttribute('aria-label', 'Copy code');
      }, 2000);
    });
  });
  wrapper.appendChild(btn);
});

function updateFavicon() {
  var logo = document.querySelector('.sidebar-brand .logo');
  if (!logo) return;
  var svgEl = logo.querySelector('svg');
  if (!svgEl) return;
  var svg = svgEl.cloneNode(true);
  ['fill', 'stroke'].forEach(function(attr) {
    var val = svg.getAttribute(attr);
    if (val && val.startsWith('var(--')) {
      var name = val.slice(4, -1);
      var resolved = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      if (resolved) svg.setAttribute(attr, resolved);
    }
  });
  var walker = document.createTreeWalker(svg, NodeFilter.SHOW_ELEMENT);
  while (walker.nextNode()) {
    var el = walker.currentNode;
    ['fill', 'stroke'].forEach(function(attr) {
      var val = el.getAttribute(attr);
      if (val && val.startsWith('var(--')) {
        var name = val.slice(4, -1);
        var resolved = getComputedStyle(document.documentElement).getPropertyValue(name).trim();
        if (resolved) el.setAttribute(attr, resolved);
      }
    });
  }
  var svgData = new XMLSerializer().serializeToString(svg);
  document.getElementById('favicon').href =
    'data:image/svg+xml,' + encodeURIComponent(svgData);
}

updateFavicon();

if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
  var revealObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(function(el) {
    revealObserver.observe(el);
  });
}

var sections = document.querySelectorAll('section[id]');
var navLinks = document.querySelectorAll('.sidebar-nav a');
var activeId = null;

function setActiveLink(id) {
  if (id === activeId) return;
  activeId = id;
  navLinks.forEach(function(link) {
    link.classList.toggle('active', link.getAttribute('href') === '#' + id);
  });
}

// Viewport-intersection spy: find the section whose range overlaps the top
// 30% of the viewport. Picks the one closest to the midpoint. Works for
// small sections that the old offsetTop approach skipped during fast scrolling.
function onScroll() {
  if (scrollingProgrammatically) return;
  var viewportTop = window.scrollY;
  var viewportMid = viewportTop + window.innerHeight * 0.3;
  var best = null;
  var bestDist = Infinity;
  for (var i = 0; i < sections.length; i++) {
    var rect = sections[i].getBoundingClientRect();
    var sectionTop = rect.top + viewportTop;
    var sectionBottom = sectionTop + rect.height;
    if (sectionTop <= viewportMid && sectionBottom >= viewportTop) {
      var dist = Math.abs(sectionTop - viewportMid);
      if (dist < bestDist) {
        bestDist = dist;
        best = sections[i];
      }
    }
  }
  if (!best && sections.length > 0) {
    best = sections[sections.length - 1];
  }
  if (best) setActiveLink(best.getAttribute('id'));
}

window.addEventListener('scroll', onScroll, { passive: true });
onScroll();
</script>
</body>
</html>