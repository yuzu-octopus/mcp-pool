{
  "name": "mcp-pool",
  "version": "0.1.4",
  "description": "MCP Key Pool Proxy — pool multiple API keys across upstream MCP servers",
  "type": "module",
  "bin": {
    "mcp-pool": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "typecheck": "tsc --project tsconfig.typecheck.json",
    "prepare": "bun run build",
    "start": "node dist/index.js",
    "dev": "bun --watch src/index.ts",
    "test": "bun test src/ test/startup-cleanup.test.ts",
    "smoke": "bun run test/smoke-test.ts",
    "check:package": "! npm pack --dry-run 2>&1 | grep -E 'dist/.*\\.test\\.(js|d\\.ts|js\\.map|d\\.ts\\.map)'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuzu-octopus/mcp-pool.git"
  },
  "bugs": {
    "url": "https://github.com/yuzu-octopus/mcp-pool/issues"
  },
  "homepage": "https://github.com/yuzu-octopus/mcp-pool#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "proxy",
    "rate-limit",
    "api-key"
  ],
  "license": "MIT"
}
